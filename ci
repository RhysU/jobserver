#!/bin/bash -eu
# Run uv-based continuous integration tests for jobserver/

# First, unit testing runs the included tests
uv run -m unittest -v ./jobserver/test_*.py

# Second, run examples to confirm they complete successfully
for ex in examples/*.py; do
    PYTHONPATH=. uv run "$ex"
done

# Then, PEP8 linting
uvx --from flake8 flake8 jobserver/ examples/

# Then, Typehint linting requires a new-enough mypy
uvx --from "mypy>0.770" mypy jobserver/

# Then, check for formatting issues
uvx --from "black<25" black --check --line-length 79 --verbose jobserver/ examples/

# Last, verify the source distribution builds correctly
uvx --from build python -m build --sdist
